# ─────────────────────────────────────────────────────────────────────────────
# Deploy configuration
# `npm run deploy` and `npm run deploy:key` read these values automatically
# (loaded by scripts/load-env.mjs — works on any Node version). Any CLI flag you
# pass still OVERRIDES the matching value here, e.g. `npm run deploy -- --supply 5000000`.
#
# This file is GIT-IGNORED — safe for secrets. Never commit it or share it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Token settings ──────────────────────────────────────────────────────────
# Display name of the token. Written to Metaplex on-chain metadata (max 32 chars)
# so Phantom/Explorer show it. Also saved to deployment.json.
TOKEN_NAME="Token Example 1"
# Ticker symbol shown in wallets/Explorer. On-chain via Metaplex (max 10 chars).
TOKEN_SYMBOL="TX1"
# Optional link to an off-chain JSON file (logo, description) — max 200 chars.
# Leave blank if you don't have one yet. Example: https://.../metadata.json
TOKEN_URI=
# How many whole tokens to mint as the initial supply.
INITIAL_SUPPLY=1000000
# Divisibility. 9 is the Solana default (1 token = 1,000,000,000 base units).
DECIMALS=9

# ── Network ─────────────────────────────────────────────────────────────────
# Which cluster to deploy to: devnet | testnet | mainnet-beta
CLUSTER=devnet
# RPC the DEPLOY SCRIPT talks to. This is the default public devnet endpoint —
# the one deploys currently run on. Swap it for a free Helius/QuickNode/Alchemy
# URL if you hit rate limits ("fetch failed" / airdrop 429).
RPC_URL=https://api.devnet.solana.com
# RPC the WEB APP (npm run dev) uses for browser reads. Fill this to avoid blank
# balances on the rate-limited public devnet RPC.
NEXT_PUBLIC_RPC_URL=

# ── Only for `npm run deploy:key` ───────────────────────────────────────────
# Your deployer private key — base58 (Phantom "Export Private Key") OR a JSON
# array of 64 numbers. Uncomment + fill to avoid typing it on the command line.
# ⚠️  Treat a mainnet key as real money. Keep this file private.
# PRIVATE_KEY=
