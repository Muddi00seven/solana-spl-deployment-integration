# Copy this file to .env.local. All values are OPTIONAL — the app defaults to
# Solana's public devnet RPC if you leave them blank.

# Custom RPC endpoint (recommended for production to avoid rate limits).
# Get a free one from Helius, QuickNode, or Alchemy.
# Example devnet: https://api.devnet.solana.com
NEXT_PUBLIC_RPC_URL=
